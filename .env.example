# Message broker
RABBITMQ_URL=amqp://<user>:<pass>@rabbitmq:5672/

# Object storage
STORAGE_PROVIDER=minio
STORAGE_BUCKET=videos
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGEME
MINIO_SECRET_KEY=CHANGEME

# Upstream services
EVENT_GATEWAY_URL=http://streaming-ingest:8080/api/v1

# Transcode worker
TRANSCODE_WORKDIR=/tmp/transcode
TRANSCODE_PROFILE=production-h264-h265-hls-dash
TRANSCODE_CODECS=h264,h265
# TRANSCODE_MAX_HEIGHT=1080   # cap the rendition ladder when CPU/RAM is limited
TRANSCODE_RETRY_QUEUE=transcode.retry
TRANSCODE_DEAD_QUEUE=transcode.dead
TRANSCODE_MAX_ATTEMPTS=3
TRANSCODE_RETRY_DELAY_SECONDS=60
TRANSCODE_QUEUE=transcode.jobs
TRANSCODE_BINDING_KEY=video.upload.completed
FFMPEG_PRESET=veryfast
# Long encodes (4K/HDR multi-rendition) may exceed the 1h default deadline.
TRANSCODE_JOB_TIMEOUT_SECONDS=10800

# Telemetry (set false when an OTLP collector is running on :4317)
OTEL_SDK_DISABLED=true
